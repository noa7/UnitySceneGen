{
  "project": {
    "name": "MyUnityProject",
    "unityVersion": "2022.3.20f1",
    "packages": [
      "com.unity.ugui",
      "com.unity.textmeshpro"
    ]
  },
  "settings": {
    "tags": ["Player", "Enemy", "UIRoot"],
    "layers": ["Gameplay", "UI"]
  },
  "scenes": [
    {
      "name": "Main",
      "path": "Assets/Scenes/Main.unity",
      "roots": ["go.root"]
    }
  ],
  "gameObjects": [
    {
      "id": "go.root",
      "name": "Root",
      "active": true,
      "tag": "Untagged",
      "layer": "Default",
      "children": ["go.camera", "go.ui"]
    },
    {
      "id": "go.camera",
      "name": "Main Camera",
      "tag": "MainCamera",
      "components": [
        {
          "type": "UnityEngine.Camera",
          "props": {
            "clearFlags": "SolidColor",
            "backgroundColor": "#202020FF",
            "fieldOfView": 60.0,
            "nearClipPlane": 0.3,
            "farClipPlane": 1000.0
          }
        },
        { "type": "UnityEngine.AudioListener" }
      ]
    },
    {
      "id": "go.ui",
      "name": "UI",
      "tag": "UIRoot",
      "layer": "UI",
      "components": [
        {
          "type": "UnityEngine.Canvas",
          "props": { "renderMode": "ScreenSpaceOverlay" }
        },
        {
          "type": "UnityEngine.UI.CanvasScaler",
          "props": {
            "uiScaleMode": "ScaleWithScreenSize",
            "referenceResolution": [1920, 1080],
            "matchWidthOrHeight": 0.5
          }
        },
        { "type": "UnityEngine.UI.GraphicRaycaster" }
      ],
      "children": ["go.ui.eventsystem", "go.ui.panel"]
    },
    {
      "id": "go.ui.eventsystem",
      "name": "EventSystem",
      "components": [
        { "type": "UnityEngine.EventSystems.EventSystem" },
        { "type": "UnityEngine.EventSystems.StandaloneInputModule" }
      ]
    },
    {
      "id": "go.ui.panel",
      "name": "Panel",
      "layer": "UI",
      "components": [
        {
          "type": "UnityEngine.RectTransform",
          "props": {
            "anchorMin": [0, 0],
            "anchorMax": [1, 1],
            "offsetMin": [0, 0],
            "offsetMax": [0, 0]
          }
        },
        {
          "type": "UnityEngine.UI.Image",
          "props": { "color": "#00000080" }
        }
      ],
      "children": ["go.ui.panel.title", "go.ui.panel.subtitle"]
    },
    {
      "id": "go.ui.panel.title",
      "name": "Title",
      "layer": "UI",
      "components": [
        {
          "type": "UnityEngine.RectTransform",
          "props": {
            "anchorMin": [0.1, 0.6],
            "anchorMax": [0.9, 0.8],
            "offsetMin": [0, 0],
            "offsetMax": [0, 0]
          }
        },
        {
          "type": "TMPro.TextMeshProUGUI",
          "props": {
            "text": "Hello World",
            "fontSize": 72,
            "alignment": "Center",
            "color": "#FFFFFFFF"
          }
        }
      ]
    },
    {
      "id": "go.ui.panel.subtitle",
      "name": "Subtitle",
      "layer": "UI",
      "components": [
        {
          "type": "UnityEngine.RectTransform",
          "props": {
            "anchorMin": [0.2, 0.45],
            "anchorMax": [0.8, 0.58],
            "offsetMin": [0, 0],
            "offsetMax": [0, 0]
          }
        },
        {
          "type": "TMPro.TextMeshProUGUI",
          "props": {
            "text": "Generated by UnitySceneGen",
            "fontSize": 32,
            "alignment": "Center",
            "color": "#CCCCCCFF"
          }
        }
      ]
    }
  ]
}
